    "@std/async": "jsr:@std/async@^1.1.0",
    "@std/cli": "jsr:@std/cli@1.0.27",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.5",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
